programa {
  funcao inicio() {
    real a, b, c, d ,soma, div

    escreva("informe sua nota: ")
    leia(a)

       escreva("informe sua nota: ")
    leia(b)

       escreva("informe sua nota: ")
    leia(c)

       escreva("informe sua nota: ")
    leia(d)

    soma = a + b + c + d
    div = soma / 4

    escreva("\nA sua média foi de: ", div)
  }
}
